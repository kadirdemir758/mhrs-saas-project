# ════════════════════════════════════════════════
#  MHRS SaaS — Environment Configuration Template
#  Copy this file to .env and fill in your values
# ════════════════════════════════════════════════

# ── Application ─────────────────────────────────
APP_NAME="MHRS SaaS"
APP_ENV=development          # development | production
DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# ── Security ─────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=your_jwt_secret_key_here_change_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_encryption_key_here_change_in_production

# Custom character substitution seed (used in encryption_utils.py)
CHAR_SUBSTITUTION_SEED=mhrs_saas_substitution_v1_secret

# ── MariaDB ──────────────────────────────────────
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=mhrs_db
MYSQL_USER=mhrs_user
MYSQL_PASSWORD=mhrs_password
DATABASE_URL=mysql+pymysql://mhrs_user:mhrs_password@localhost:3306/mhrs_db

# ── RabbitMQ ─────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=mhrs_rabbit
RABBITMQ_PASS=rabbitpass
RABBITMQ_VHOST=mhrs_vhost
RABBITMQ_URL=amqp://mhrs_rabbit:rabbitpass@localhost:5672/mhrs_vhost

# ── Elasticsearch ─────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX_DOCTORS=doctors

# ── SMTP — Email Service ─────────────────────────
# For Gmail: use App Password, not your regular Gmail password
# Google Account → Security → 2FA → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password_here
SMTP_FROM_NAME="MHRS Sistem"
SMTP_FROM_EMAIL=your_email@gmail.com

# ── Admin ────────────────────────────────────────
ADMIN_EMAIL=admin@mhrs.com
ADMIN_PASSWORD=Admin1234!

# ── Ubuntu VM (for CI/CD deployment) ────────────
VM_HOST=192.168.1.100      # Your Ubuntu VM IP (bridged adapter)
VM_USER=ubuntu
VM_DEPLOY_PATH=/opt/mhrs-saas
